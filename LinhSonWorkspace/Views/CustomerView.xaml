<UserControl x:Class="LinhSonWorkspace.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinhSonWorkspace.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="👤" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Quản lý Khách hàng" FontSize="26" FontWeight="Bold" Foreground="#1F2937"/>
            <Button Content="+ Thêm mới" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="20,0,0,0" VerticalAlignment="Center" Padding="15,8"/>
            <Button Content="🔄" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Compact Filter Bar - matching CheckInOut style -->
        <Border Grid.Row="1" Style="{StaticResource ContentCard}" Margin="0,0,0,15" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}" Width="250" Height="32" 
                         FontSize="12" Padding="8,4" VerticalContentAlignment="Center"/>
                <Border Background="#ECFDF5" CornerRadius="6" Padding="8,4" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Customers.Count, StringFormat='📋 {0} khách hàng'}" 
                               Foreground="#10B981" FontWeight="SemiBold" FontSize="11"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ContentCard}">
            <DataGrid ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" AutoGenerateColumns="False" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="SĐT" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Công ty" Binding="{Binding Company}" Width="130"/>
                    <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="✏️ Sửa" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
            <Button Content="🗑️ Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
        </StackPanel>

        <!-- Edit Overlay - Expanded for Desktop -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#40000000" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <Border Background="#FFFFFF" CornerRadius="16" Padding="30" MaxWidth="600" MaxHeight="580" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Effect="{StaticResource ElevatedShadow}">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,20">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="✏️ Chỉnh sửa Khách hàng"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAddMode}" Value="True">
                                        <Setter Property="Text" Value="➕ Thêm Khách hàng mới"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Border Height="1" Background="#F3F4F6" Margin="0,0,0,18"/>

                    <!-- Row 1: Name & Phone -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="15"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Họ tên *" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditName}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Số điện thoại" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditPhone}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Email & Company -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="15"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Email" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditEmail}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Công ty / Tổ chức" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditCompany}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 3: Address -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Địa chỉ" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditAddress}" Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <!-- Row 4: Note -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Ghi chú" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditNote}" Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" AcceptsReturn="True" Height="70"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Command="{Binding CancelEditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                        <Button Content="💾 Lưu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
