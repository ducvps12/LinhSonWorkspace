<UserControl x:Class="LinhSonWorkspace.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinhSonWorkspace.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Quản lý Khách hàng" FontSize="26" FontWeight="Bold" Foreground="#ccd6f6"/>
            <Button Content="+ Thêm mới" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="20,0,0,0" VerticalAlignment="Center" Padding="15,6"/>
            <Button Content="🔄" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ContentCard}" Margin="0,0,0,15" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Width="300"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ContentCard}">
            <DataGrid ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" AutoGenerateColumns="False" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="SĐT" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="✏️ Sửa" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
            <Button Content="🗑️ Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
        </StackPanel>

        <!-- Edit Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <Border Background="#1e293b" CornerRadius="12" Padding="25" MaxWidth="420" MaxHeight="400" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Thông tin Khách hàng" FontSize="18" FontWeight="Bold" Foreground="#ccd6f6" Margin="0,0,0,15"/>
                    <TextBlock Text="Họ tên:" Foreground="#8892b0" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditName}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    <TextBlock Text="SĐT:" Foreground="#8892b0" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditPhone}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    <TextBlock Text="Email:" Foreground="#8892b0" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditEmail}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    <TextBlock Text="Ghi chú:" Foreground="#8892b0" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditNote}" Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" Height="50" Margin="0,0,0,15"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Command="{Binding CancelEditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                        <Button Content="💾 Lưu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
