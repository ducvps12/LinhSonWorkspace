<UserControl x:Class="LinhSonWorkspace.Views.CheckInOutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinhSonWorkspace.Converters">
    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="✅" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Check In / Check Out" FontSize="26" FontWeight="Bold" Foreground="#1F2937"/>
            <Button Content="🔄" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="20,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ContentCard}" Margin="0,0,0,15" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Lọc theo:" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding FilterStatus}" Style="{StaticResource ModernComboBox}" Width="140"/>
                <Border Background="#ECFDF5" CornerRadius="6" Padding="8,4" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="📅 Booking hôm nay" Foreground="#10B981" FontWeight="SemiBold" FontSize="12"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ContentCard}">
            <DataGrid ItemsSource="{Binding TodayBookings}" SelectedItem="{Binding SelectedBooking}" AutoGenerateColumns="False" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding BookingCode}" Width="70"/>
                    <DataGridTextColumn Header="Khách hàng" Binding="{Binding Customer.FullName}" Width="*"/>
                    <DataGridTextColumn Header="Workspace" Binding="{Binding Workspace.Name}" Width="150"/>
                    <DataGridTextColumn Header="Giờ BĐ" Binding="{Binding StartTime, StringFormat=HH:mm}" Width="70"/>
                    <DataGridTextColumn Header="Giờ KT" Binding="{Binding EndTime, StringFormat=HH:mm}" Width="70"/>
                    <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalPrice, Converter={StaticResource CurrencyConverter}}" Width="110"/>
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}" CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="📥 CHECK IN" Command="{Binding CheckInCommand}" Style="{StaticResource PrimaryButton}" Padding="28,12" FontSize="14" Margin="0,0,20,0"/>
            <Button Content="📤 CHECK OUT" Command="{Binding CheckOutCommand}" Style="{StaticResource SuccessButton}" Padding="28,12" FontSize="14"/>
        </StackPanel>
    </Grid>
</UserControl>
