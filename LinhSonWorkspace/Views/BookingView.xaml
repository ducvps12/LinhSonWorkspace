<UserControl x:Class="LinhSonWorkspace.Views.BookingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinhSonWorkspace.Converters">
    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title & Actions -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Quản lý Đặt lịch" FontSize="26" FontWeight="Bold" Foreground="#ccd6f6"/>
            <Button Content="+ Tạo Booking" Command="{Binding CreateBookingCommand}" Style="{StaticResource PrimaryButton}" Margin="20,0,10,0" VerticalAlignment="Center" Padding="15,6"/>
            <Button Content="📄 CSV" Command="{Binding ExportCsvCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <Button Content="📋 JSON" Command="{Binding ExportJsonCommand}" Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource ContentCard}" Margin="0,0,0,15" Padding="15">
            <WrapPanel>
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Width="180" Margin="0,0,15,0"/>
                <TextBlock Text="Status:" Foreground="#8892b0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding FilterStatus}" Style="{StaticResource ModernComboBox}" Width="120" Margin="0,0,15,0"/>
                <TextBlock Text="Từ:" Foreground="#8892b0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker SelectedDate="{Binding FilterDateFrom}" Width="130" Margin="0,0,15,0"/>
                <TextBlock Text="Đến:" Foreground="#8892b0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker SelectedDate="{Binding FilterDateTo}" Width="130"/>
            </WrapPanel>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Style="{StaticResource ContentCard}">
            <DataGrid ItemsSource="{Binding Bookings}" SelectedItem="{Binding SelectedBooking}" AutoGenerateColumns="False" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding BookingCode}" Width="70"/>
                    <DataGridTextColumn Header="Khách hàng" Binding="{Binding Customer.FullName}" Width="*"/>
                    <DataGridTextColumn Header="Workspace" Binding="{Binding Workspace.Name}" Width="130"/>
                    <DataGridTextColumn Header="Bắt đầu" Binding="{Binding StartTime, StringFormat=dd/MM HH:mm}" Width="95"/>
                    <DataGridTextColumn Header="Kết thúc" Binding="{Binding EndTime, StringFormat=dd/MM HH:mm}" Width="95"/>
                    <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalPrice, Converter={StaticResource CurrencyConverter}}" Width="110"/>
                    <DataGridTemplateColumn Header="Status" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Tạo bởi" Binding="{Binding CreatedByUser.FullName}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="✅ Confirm" Command="{Binding ConfirmBookingCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
            <Button Content="❌ Hủy Booking" Command="{Binding CancelBookingCommand}" Style="{StaticResource DangerButton}"/>
        </StackPanel>

        <!-- Create Booking Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000" Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}}">
            <Border Background="#1e293b" CornerRadius="12" Padding="25" MaxWidth="500" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource CardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="🆕 Tạo Booking mới" FontSize="18" FontWeight="Bold" Foreground="#ccd6f6" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Khách hàng:" Foreground="#8892b0" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding AllCustomers}" SelectedItem="{Binding NewCustomer}" DisplayMemberPath="FullName" Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Workspace:" Foreground="#8892b0" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding AvailableWorkspaces}" SelectedItem="{Binding NewWorkspace}" DisplayMemberPath="Name" Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition Width="60"/><ColumnDefinition Width="5"/><ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ngày bắt đầu:" Foreground="#8892b0" Margin="0,0,0,3"/>
                                <DatePicker SelectedDate="{Binding NewStartDate}" Width="Auto"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Giờ:" Foreground="#8892b0" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding NewStartHour}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Phút:" Foreground="#8892b0" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding NewStartMinute}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition Width="60"/><ColumnDefinition Width="5"/><ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ngày kết thúc:" Foreground="#8892b0" Margin="0,0,0,3"/>
                                <DatePicker SelectedDate="{Binding NewEndDate}" Width="Auto"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Giờ:" Foreground="#8892b0" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding NewEndHour}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Phút:" Foreground="#8892b0" Margin="0,0,0,3"/>
                                <TextBox Text="{Binding NewEndMinute}" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Ghi chú:" Foreground="#8892b0" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding NewNote}" Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" Height="45" Margin="0,0,0,10"/>

                        <!-- Price -->
                        <Border Background="#0d1117" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="💰 Tổng tiền: " Foreground="#8892b0" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CalculatedPrice, Converter={StaticResource CurrencyConverter}}" 
                                           FontSize="22" FontWeight="Bold" Foreground="#f59e0b"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Hủy" Command="{Binding CancelCreateCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                            <Button Content="💾 Tạo Booking" Command="{Binding SaveBookingCommand}" Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>
