<UserControl x:Class="LinhSonWorkspace.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinhSonWorkspace.Converters">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,20,20">
                
                <!-- Page Title -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="⚙️" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Cài đặt hệ thống" FontSize="26" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                    <Border Background="#FFF7ED" CornerRadius="6" Padding="10,4" Margin="15,0,0,0" VerticalAlignment="Center"
                            BorderBrush="#FED7AA" BorderThickness="1">
                        <TextBlock Text="🔒 Admin Only" Foreground="#E86830" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Status Message -->
                <Border Margin="0,0,0,15" CornerRadius="10" Padding="14,10"
                        Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#ECFDF5"/>
                            <Setter Property="BorderBrush" Value="#A7F3D0"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                    <Setter Property="Background" Value="#FEF2F2"/>
                                    <Setter Property="BorderBrush" Value="#FECACA"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#059669"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- ==================== USER MANAGEMENT ==================== -->
                <Border Style="{StaticResource ContentCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#F3E8FF" CornerRadius="10" Width="40" Height="40" Margin="0,0,12,0">
                                <TextBlock Text="👥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Quản lý Người Dùng" FontSize="16" FontWeight="Bold" Foreground="#1F2937"/>
                                <TextBlock Text="Thêm, sửa, reset mật khẩu nhân viên/admin" FontSize="11" Foreground="#9CA3AF"/>
                            </StackPanel>
                            <Button Content="+ Thêm User" Command="{Binding AddUserCommand}" Style="{StaticResource PrimaryButton}" Margin="20,0,0,0" Padding="15,6"/>
                            <Button Content="🔄" Command="{Binding RefreshUsersCommand}" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"/>
                        </StackPanel>
                        
                        <Border Height="1" Background="#F3F4F6" Margin="0,0,0,15"/>

                        <DataGrid ItemsSource="{Binding UsersList}" SelectedItem="{Binding SelectedUser}" 
                                  AutoGenerateColumns="False" Style="{StaticResource ModernDataGrid}" MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tài khoản" Binding="{Binding Username}" Width="120"/>
                                <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                                <DataGridTextColumn Header="Vai trò" Binding="{Binding Role.RoleName}" Width="80"/>
                                <DataGridTemplateColumn Header="Trạng thái" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding IsActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" CornerRadius="4" Padding="6,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#10B981"/> <!-- Green if active -->
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Background" Value="#EF4444"/> <!-- Red if inactive -->
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding IsActive, StringFormat='{}{0}'}" Foreground="White" FontSize="10" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Active"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Text" Value="Disabled"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                            <Button Content="✏️ Sửa" Command="{Binding EditUserCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                            <Button Content="🔑 Reset Password" Command="{Binding ResetPasswordCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                            <Button Content="🚫 Khóa / Mở Khóa" Command="{Binding ToggleStatusCommand}" Style="{StaticResource DangerButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ==================== SMTP CONFIGURATION ==================== -->
                <Border Style="{StaticResource ContentCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#FFF7ED" CornerRadius="10" Width="40" Height="40" Margin="0,0,12,0">
                                <TextBlock Text="📧" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Cấu hình Email SMTP" FontSize="16" FontWeight="Bold" Foreground="#1F2937"/>
                                <TextBlock Text="Cấu hình máy chủ gửi email tự động" FontSize="11" Foreground="#9CA3AF"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Height="1" Background="#F3F4F6" Margin="0,0,0,15"/>

                        <!-- SMTP Host & Port -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SMTP Host" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="VD: smtp.gmail.com, smtp.mail.yahoo.com" 
                                           Foreground="#9CA3AF" FontSize="10" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="587 (TLS) hoặc 465 (SSL)" 
                                           Foreground="#9CA3AF" FontSize="10" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Email & Password -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Email SMTP" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SmtpEmail, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Mật khẩu / App Password" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SmtpPassword, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="Dùng App Password nếu bật 2FA" 
                                           Foreground="#9CA3AF" FontSize="10" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Display Name & Enable SSL -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tên hiển thị" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding SmtpDisplayName, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="Tên hiện trong email gửi đi" 
                                           Foreground="#9CA3AF" FontSize="10" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding SmtpEnableSsl}" Margin="0,12,0,0">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Foreground" Value="#1F2937"/>
                                            <Setter Property="FontSize" Value="13"/>
                                        </Style>
                                    </CheckBox.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔒 Bật SSL/TLS" Foreground="#1F2937" FontSize="13"/>
                                    </StackPanel>
                                </CheckBox>
                                <TextBlock Text="Bắt buộc cho Gmail, Outlook" 
                                           Foreground="#9CA3AF" FontSize="10" Margin="18,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Save SMTP Button -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Lưu cấu hình SMTP" Command="{Binding SaveSmtpCommand}" 
                                    Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ==================== TEST EMAIL ==================== -->
                <Border Style="{StaticResource ContentCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#ECFDF5" CornerRadius="10" Width="40" Height="40" Margin="0,0,12,0">
                                <TextBlock Text="🧪" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Gửi email thử nghiệm" FontSize="16" FontWeight="Bold" Foreground="#1F2937"/>
                                <TextBlock Text="Kiểm tra cấu hình SMTP có hoạt động không" FontSize="11" Foreground="#9CA3AF"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Height="1" Background="#F3F4F6" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Email nhận thử" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding TestEmailAddress, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <Button Grid.Column="2" Content="📤 Gửi thử" Command="{Binding SendTestEmailCommand}" 
                                    Style="{StaticResource SuccessButton}" VerticalAlignment="Bottom" Padding="20,10"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ==================== GENERAL SETTINGS ==================== -->
                <Border Style="{StaticResource ContentCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#EFF6FF" CornerRadius="10" Width="40" Height="40" Margin="0,0,12,0">
                                <TextBlock Text="🏢" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Cấu hình chung" FontSize="16" FontWeight="Bold" Foreground="#1F2937"/>
                                <TextBlock Text="Thông tin cơ bản của workspace" FontSize="11" Foreground="#9CA3AF"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Height="1" Background="#F3F4F6" Margin="0,0,0,15"/>

                        <!-- App Title -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Tên ứng dụng" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AppTitle, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <!-- Contact Phone & Email -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Số điện thoại liên hệ" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ContactPhone, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Email liên hệ" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ContactEmail, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Address -->
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Địa chỉ" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" 
                                     AcceptsReturn="True" Height="60"/>
                        </StackPanel>

                        <!-- Save General Button -->
                        <Button Content="💾 Lưu cấu hình chung" Command="{Binding SaveGeneralCommand}" 
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- ==================== SMTP GUIDE ==================== -->
                <Border Style="{StaticResource ContentCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Background="#F5F3FF" CornerRadius="10" Width="40" Height="40" Margin="0,0,12,0">
                                <TextBlock Text="📖" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Hướng dẫn cấu hình SMTP" FontSize="16" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <Border Height="1" Background="#F3F4F6" Margin="0,0,0,15"/>

                        <!-- Gmail -->
                        <Border Background="#F9FAFB" CornerRadius="10" Padding="16" Margin="0,0,0,10" 
                                BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="📌 Gmail" FontSize="13" FontWeight="Bold" Foreground="#E86830" Margin="0,0,0,6"/>
                                <TextBlock Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" LineHeight="22">
                                    <Run Text="• Host: smtp.gmail.com"/>
                                    <LineBreak/>
                                    <Run Text="• Port: 587 (TLS)"/>
                                    <LineBreak/>
                                    <Run Text="• SSL: Bật"/>
                                    <LineBreak/>
                                    <Run Text="• Lưu ý: Phải dùng App Password (Mật khẩu ứng dụng)"/>
                                    <LineBreak/>
                                    <Run Text="  → Vào Google Account → Security → 2-Step Verification → App Passwords"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Outlook -->
                        <Border Background="#F9FAFB" CornerRadius="10" Padding="16" Margin="0,0,0,10"
                                BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="📌 Outlook / Hotmail" FontSize="13" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,0,6"/>
                                <TextBlock Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" LineHeight="22">
                                    <Run Text="• Host: smtp-mail.outlook.com"/>
                                    <LineBreak/>
                                    <Run Text="• Port: 587"/>
                                    <LineBreak/>
                                    <Run Text="• SSL: Bật"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Yahoo -->
                        <Border Background="#F9FAFB" CornerRadius="10" Padding="16"
                                BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="📌 Yahoo Mail" FontSize="13" FontWeight="Bold" Foreground="#8B5CF6" Margin="0,0,0,6"/>
                                <TextBlock Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" LineHeight="22">
                                    <Run Text="• Host: smtp.mail.yahoo.com"/>
                                    <LineBreak/>
                                    <Run Text="• Port: 587"/>
                                    <LineBreak/>
                                    <Run Text="• SSL: Bật"/>
                                    <LineBreak/>
                                    <Run Text="• Lưu ý: Cần bật 'Allow apps that use less secure sign in'"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Edit User Overlay -->
        <Border Background="#40000000" Visibility="{Binding IsEditingUser, Converter={StaticResource BoolToVis}}">
            <Border Background="#FFFFFF" CornerRadius="16" Padding="30" MaxWidth="500" MaxHeight="600" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#E5E7EB" BorderThickness="1"
                    Effect="{StaticResource ElevatedShadow}">
                <StackPanel>
                    <TextBlock Text="Thông tin Người dùng" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,18"/>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="15"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tên đăng nhập:" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditUsername}" Style="{StaticResource ModernTextBox}" IsEnabled="{Binding IsAddUserMode}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Họ tên:" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditFullName}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Email:" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditEmail}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="SĐT:" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditPhone}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="15"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Vai trò:" Foreground="#6B7280" FontSize="12" FontWeight="Medium" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding RolesList}" DisplayMemberPath="RoleName" SelectedValuePath="RoleId"
                                      SelectedValue="{Binding EditRoleId}" Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                            <CheckBox IsChecked="{Binding EditIsActive}" Content="Tài khoản hoạt động" Foreground="#1F2937" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Command="{Binding CancelEditUserCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                        <Button Content="💾 Lưu thông tin" Command="{Binding SaveUserCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
