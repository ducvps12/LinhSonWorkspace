<Window x:Class="LinhSonWorkspace.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LinhSonWorkspace.ViewModels"
        Title="Linh Son Workspace - Đăng Nhập" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side: Branding / Welcome -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E86830" Offset="0"/>
                    <GradientStop Color="#D55A24" Offset="0.5"/>
                    <GradientStop Color="#C04E1C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <!-- Decorative background elements -->
            <Grid ClipToBounds="True">
                <Ellipse Width="300" Height="300" Fill="#FFFFFF" Opacity="0.05" Margin="-100,-100,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                <Ellipse Width="400" Height="400" Fill="#000000" Opacity="0.05" Margin="0,0,-150,-150" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <!-- Modern Vector Icon (Office Building) -->
                    <Border Background="#FFFFFF" CornerRadius="24" Width="90" Height="90" Margin="0,0,0,25"
                            Effect="{StaticResource ElevatedShadow}">
                        <Viewbox Width="40" Height="40">
                            <Path Fill="#E86830" Data="M17,11V3H7V4H3V14H5V22H19V14H21V11H17M7,19H5V16H7V19M7,13H5V10H7V13M7,7H5V5H7V7M11,19H9V16H11V19M11,13H9V10H11V13M11,7H9V5H11V7M15,19H13V16H15V19M15,13H13V10H15V13M15,7H13V5H15V7M19,13H17V10H19V13Z"/>
                        </Viewbox>
                    </Border>

                    <TextBlock Text="LINH SON" FontSize="36" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,0"/>
                    <TextBlock Text="WORKSPACE" FontSize="18" FontWeight="SemiBold" Foreground="#FFD7C4" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                    
                    <Border Width="40" Height="4" Background="#FFFFFF" CornerRadius="2" Margin="0,25,0,25" Opacity="0.5"/>
                    
                    <TextBlock Text="Hệ thống quản lý không gian làm việc chuyên nghiệp, giúp bạn tối ưu hóa vận hành và nâng cao trải nghiệm khách hàng." 
                               Foreground="#FFEDD5" TextWrapping="Wrap" TextAlignment="Center" FontSize="14" LineHeight="22" Opacity="0.9"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Side: Login Form -->
        <Border Grid.Column="1" Background="#FFFFFF">
            <Grid Margin="50,30">
                <StackPanel VerticalAlignment="Center" MaxWidth="340">
                    <!-- Greeting -->
                    <TextBlock Text="Chào mừng trở lại! 👋" FontSize="28" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,8" FontFamily="Segoe UI"/>
                    <TextBlock Text="Vui lòng đăng nhập vào tài khoản của bạn để tiếp tục." FontSize="14" Foreground="#6B7280" Margin="0,0,0,30"/>

                    <!-- Form -->
                    <TextBlock Text="Tên đăng nhập" Foreground="#4B5563" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtUsername" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}" Height="44" Margin="0,0,0,16"/>

                    <TextBlock Text="Mật khẩu" Foreground="#4B5563" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBox}" Height="44" Margin="0,0,0,6"/>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="13" FontWeight="Medium"
                               Margin="0,4,0,16" TextWrapping="Wrap" MinHeight="18"/>

                    <Button Content="ĐĂNG NHẬP" Command="{Binding LoginCommand}" 
                            Style="{StaticResource PrimaryButton}" Height="46" FontSize="14" Margin="0,0,0,16"
                            Effect="{StaticResource CardShadow}"/>

                    <!-- Divider -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="1" Background="#E5E7EB" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="hoặc" Foreground="#9CA3AF" FontSize="12" Margin="12,0"/>
                        <Border Grid.Column="2" Height="1" Background="#E5E7EB" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Google Sign-In Button -->
                    <Button Command="{Binding GoogleLoginCommand}" Height="46" Margin="0,0,0,30" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="googleBorder" Background="#FFFFFF" CornerRadius="8" 
                                        BorderBrush="#D1D5DB" BorderThickness="1.5" Padding="12,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <!-- Google G Logo using Path -->
                                        <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                                            <Canvas Width="48" Height="48">
                                                <Path Fill="#EA4335" Data="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                                <Path Fill="#4285F4" Data="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                                <Path Fill="#FBBC05" Data="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                                <Path Fill="#34A853" Data="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="Đăng nhập bằng Google" FontSize="14" FontWeight="SemiBold" 
                                                   Foreground="#374151" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="googleBorder" Property="Background" Value="#F9FAFB"/>
                                        <Setter TargetName="googleBorder" Property="BorderBrush" Value="#9CA3AF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="googleBorder" Property="Background" Value="#F3F4F6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Demo Accounts -->
                    <Border Background="#F9FAFB" CornerRadius="12" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="ℹ️" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tài khoản dùng thử" Foreground="#4B5563" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#FFF7ED" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                    <TextBlock Grid.Column="0" Text="Admin" Foreground="#E86830" FontSize="11" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="admin / admin123" Foreground="#374151" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#F3F4F6" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                    <TextBlock Grid.Column="0" Text="Staff" Foreground="#6B7280" FontSize="11" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="staff1 / staff123" Foreground="#374151" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
