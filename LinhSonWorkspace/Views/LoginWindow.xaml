<Window x:Class="LinhSonWorkspace.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LinhSonWorkspace.ViewModels"
        Title="Linh Son Workspace - Đăng Nhập" 
        Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a1a2e">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <Border Background="#16213e" CornerRadius="16" Margin="30" Padding="30"
                Effect="{StaticResource CardShadow}">
            <StackPanel VerticalAlignment="Center">
                <!-- Logo / Title -->
                <TextBlock Text="🏢" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="LINH SON WORKSPACE" FontSize="20" FontWeight="Bold" 
                           Foreground="#00b4d8" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Booking Management System" FontSize="12" 
                           Foreground="#8892b0" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Username -->
                <TextBlock Text="Tên đăng nhập" Foreground="#ccd6f6" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                <!-- Password -->
                <TextBlock Text="Mật khẩu" Foreground="#ccd6f6" FontSize="12" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,5"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#ef4444" FontSize="12" 
                           Margin="0,5,0,15" TextWrapping="Wrap"/>

                <!-- Login Button -->
                <Button Content="ĐĂNG NHẬP" Command="{Binding LoginCommand}" 
                        Style="{StaticResource PrimaryButton}" Height="42" FontSize="14"/>

                <!-- Info -->
                <TextBlock Text="Admin: admin / admin123  |  Staff: staff1 / staff123" 
                           Foreground="#4a5568" FontSize="10" HorizontalAlignment="Center" 
                           Margin="0,15,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
