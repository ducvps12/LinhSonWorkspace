<UserControl x:Class="LinhSonWorkspace.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinhSonWorkspace.Converters">

    <UserControl.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Title -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="📊" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold" Foreground="#1F2937"/>
            </StackPanel>

            <!-- Stats Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <!-- Today Bookings -->
                <Border Style="{StaticResource StatsCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <Border Background="#FFF7ED" CornerRadius="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="📅" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TodayBookings}" FontSize="32" FontWeight="Bold" Foreground="#E86830"/>
                        <TextBlock Text="Booking hôm nay" Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Active Workspaces -->
                <Border Style="{StaticResource StatsCard}" Margin="5,0">
                    <StackPanel>
                        <Border Background="#ECFDF5" CornerRadius="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="🏢" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding ActiveWorkspaces}" FontSize="32" FontWeight="Bold" Foreground="#10B981"/>
                        <TextBlock Text="Đang sử dụng" Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Today Revenue -->
                <Border Style="{StaticResource StatsCard}" Margin="5,0">
                    <StackPanel>
                        <Border Background="#FFFBEB" CornerRadius="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="💰" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TodayRevenue, Converter={StaticResource CurrencyConverter}}" 
                                   FontSize="20" FontWeight="Bold" Foreground="#F59E0B"/>
                        <TextBlock Text="Doanh thu hôm nay" Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Total Customers -->
                <Border Style="{StaticResource StatsCard}" Margin="10,0,0,0">
                    <StackPanel>
                        <Border Background="#F5F3FF" CornerRadius="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="👥" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TotalCustomers}" FontSize="32" FontWeight="Bold" Foreground="#8B5CF6"/>
                        <TextBlock Text="Khách hàng" Foreground="#6B7280" FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Two columns: Upcoming & Recent -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Upcoming Bookings -->
                <Border Grid.Column="0" Style="{StaticResource ContentCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📋 Booking sắp tới" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding UpcomingBookings}" AutoGenerateColumns="False"
                                  Style="{StaticResource ModernDataGrid}" MaxHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã" Binding="{Binding BookingCode}" Width="60"/>
                                <DataGridTextColumn Header="Khách" Binding="{Binding Customer.FullName}" Width="*"/>
                                <DataGridTextColumn Header="Workspace" Binding="{Binding Workspace.Name}" Width="*"/>
                                <DataGridTextColumn Header="Giờ BĐ" Binding="{Binding StartTime, StringFormat=HH:mm}" Width="55"/>
                                <DataGridTemplateColumn Header="Status" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}" 
                                                    CornerRadius="4" Padding="5,2">
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Recent Bookings -->
                <Border Grid.Column="1" Style="{StaticResource ContentCard}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🕐 Booking gần đây" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding RecentBookings}" AutoGenerateColumns="False"
                                  Style="{StaticResource ModernDataGrid}" MaxHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã" Binding="{Binding BookingCode}" Width="60"/>
                                <DataGridTextColumn Header="Khách" Binding="{Binding Customer.FullName}" Width="*"/>
                                <DataGridTextColumn Header="Workspace" Binding="{Binding Workspace.Name}" Width="*"/>
                                <DataGridTemplateColumn Header="Status" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}" 
                                                    CornerRadius="4" Padding="5,2">
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
