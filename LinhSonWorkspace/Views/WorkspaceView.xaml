<UserControl x:Class="LinhSonWorkspace.Views.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LinhSonWorkspace.Converters">
    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Quản lý Workspace" FontSize="26" FontWeight="Bold" Foreground="#ccd6f6"/>
            <Button Content="+ Thêm mới" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" 
                    Margin="20,0,0,0" VerticalAlignment="Center" Padding="15,6"/>
            <Button Content="🔄" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" 
                    Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource ContentCard}" Margin="0,0,0,15" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}" Width="200" Margin="0,0,15,0"/>
                <TextBlock Text="Loại:" Foreground="#8892b0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding WorkspaceTypes}" SelectedItem="{Binding FilterType}"
                          Style="{StaticResource ModernComboBox}" Width="140" Margin="0,0,15,0"/>
                <TextBlock Text="Trạng thái:" Foreground="#8892b0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding FilterStatus}"
                          Style="{StaticResource ModernComboBox}" Width="120"/>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Style="{StaticResource ContentCard}">
            <DataGrid ItemsSource="{Binding Workspaces}" SelectedItem="{Binding SelectedWorkspace}"
                      AutoGenerateColumns="False" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding WorkspaceType.TypeName}" Width="120"/>
                    <DataGridTextColumn Header="Sức chứa" Binding="{Binding Capacity}" Width="70"/>
                    <DataGridTextColumn Header="Giá/Giờ" Binding="{Binding PricePerHour, Converter={StaticResource CurrencyConverter}}" Width="110"/>
                    <DataGridTextColumn Header="Giá/Ngày" Binding="{Binding PricePerDay, Converter={StaticResource CurrencyConverter}}" Width="110"/>
                    <DataGridTemplateColumn Header="Trạng thái" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}" 
                                        CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="✏️ Sửa" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
            <Button Content="🗑️ Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
        </StackPanel>

        <!-- Edit Panel (Overlay) -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000" 
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <Border Background="#1e293b" CornerRadius="12" Padding="25" MaxWidth="450" MaxHeight="520"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="{Binding IsAddMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}" 
                               FontSize="18" FontWeight="Bold" Foreground="#ccd6f6" Margin="0,0,0,15"/>
                    <TextBlock Text="Tên workspace:" Foreground="#8892b0" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditName}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    <TextBlock Text="Loại:" Foreground="#8892b0" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding AllTypes}" DisplayMemberPath="TypeName" SelectedValuePath="TypeId"
                              SelectedValue="{Binding EditTypeId}" Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"/>
                    <TextBlock Text="Sức chứa:" Foreground="#8892b0" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditCapacity}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Giá/Giờ:" Foreground="#8892b0" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding EditPricePerHour}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giá/Ngày:" Foreground="#8892b0" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding EditPricePerDay}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Trạng thái:" Foreground="#8892b0" Margin="0,10,0,3"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding EditStatus}"
                              Style="{StaticResource ModernComboBox}" Margin="0,0,0,10"/>
                    <TextBlock Text="Mô tả:" Foreground="#8892b0" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding EditDescription}" Style="{StaticResource ModernTextBox}" 
                             TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,0,0,15"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Command="{Binding CancelEditCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                        <Button Content="💾 Lưu" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
