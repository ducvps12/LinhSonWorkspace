<UserControl x:Class="LinhSonWorkspace.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:converters="clr-namespace:LinhSonWorkspace.Converters">
    <UserControl.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Báo cáo &amp; Thống kê" FontSize="26" FontWeight="Bold" Foreground="#ccd6f6" Margin="0,0,0,15"/>

            <!-- Date Range -->
            <Border Style="{StaticResource ContentCard}" Margin="0,0,0,15" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Từ ngày:" Foreground="#8892b0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding DateFrom}" Width="140" Margin="0,0,15,0"/>
                    <TextBlock Text="Đến ngày:" Foreground="#8892b0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding DateTo}" Width="140" Margin="0,0,15,0"/>
                    <Button Content="🔄 Cập nhật" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Border>

            <!-- Stats -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource StatsCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="24"/>
                        <TextBlock Text="{Binding TotalRevenue, Converter={StaticResource CurrencyConverter}}" FontSize="18" FontWeight="Bold" Foreground="#f59e0b"/>
                        <TextBlock Text="Tổng doanh thu" Foreground="#8892b0" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatsCard}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="📅" FontSize="24"/>
                        <TextBlock Text="{Binding TotalBookings}" FontSize="28" FontWeight="Bold" Foreground="#00b4d8"/>
                        <TextBlock Text="Tổng booking" Foreground="#8892b0" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatsCard}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="✅" FontSize="24"/>
                        <TextBlock Text="{Binding CompletedBookings}" FontSize="28" FontWeight="Bold" Foreground="#10b981"/>
                        <TextBlock Text="Hoàn thành" Foreground="#8892b0" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatsCard}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🏆" FontSize="24"/>
                        <TextBlock Text="{Binding TopWorkspace}" FontSize="13" FontWeight="Bold" Foreground="#a78bfa" TextWrapping="Wrap"/>
                        <TextBlock Text="Top workspace" Foreground="#8892b0" FontSize="11"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Revenue Chart -->
                <Border Grid.Column="0" Style="{StaticResource ContentCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📊 Doanh thu theo ngày" FontSize="14" FontWeight="SemiBold" Foreground="#ccd6f6" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Series="{Binding RevenueSeries}" XAxes="{Binding RevenueXAxes}" Height="280"/>
                    </StackPanel>
                </Border>

                <!-- Booking Status Pie -->
                <Border Grid.Column="1" Style="{StaticResource ContentCard}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🍩 Trạng thái booking" FontSize="14" FontWeight="SemiBold" Foreground="#ccd6f6" Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding BookingStatusSeries}" Height="280"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
