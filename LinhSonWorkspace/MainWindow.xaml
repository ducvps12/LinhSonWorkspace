<Window x:Class="LinhSonWorkspace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LinhSonWorkspace.ViewModels"
        xmlns:views="clr-namespace:LinhSonWorkspace.Views"
        xmlns:converters="clr-namespace:LinhSonWorkspace.Converters"
        Title="Linh Son Workspace - Booking Management" 
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
            <views:WorkspaceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerViewModel}">
            <views:CustomerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookingViewModel}">
            <views:BookingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CheckInOutViewModel}">
            <views:CheckInOutView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>

        <!-- Converter for Settings status message -->
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header / Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FFF7ED" CornerRadius="10" Width="40" Height="40" Margin="0,0,12,0">
                            <TextBlock Text="🏢" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="LINH SON" FontSize="17" FontWeight="Bold" Foreground="#E86830"/>
                            <TextBlock Text="WORKSPACE" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold" 
                                       Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="#F3F4F6" Margin="0,18,0,0"/>
                </StackPanel>

                <!-- User Info at bottom -->
                <Border DockPanel.Dock="Bottom" Background="#F9FAFB" Padding="16,12" Margin="12,0,12,12" 
                        CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="#E86830" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                                <TextBlock Text="👤" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUserName}" Foreground="#1F2937" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CurrentRole}" Foreground="#E86830" FontSize="10" FontWeight="Medium"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="🚪 Đăng xuất" Command="{Binding LogoutCommand}" 
                                Style="{StaticResource SidebarButton}" Foreground="#EF4444" Margin="0,8,0,0"
                                FontSize="11" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Menu Items -->
                <StackPanel Margin="12,0">
                    <TextBlock Text="MENU" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" 
                               Margin="14,0,0,8"/>
                    <RadioButton Content="📊  Dashboard" GroupName="Menu" IsChecked="True"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
                    <RadioButton Content="🏠  Workspaces"  GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Workspaces"/>
                    <RadioButton Content="👤  Khách hàng" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Customers"/>
                    <RadioButton Content="📅  Đặt lịch" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Bookings"/>
                    <RadioButton Content="✅  Check In/Out" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="CheckInOut"/>
                    <RadioButton Content="📈  Báo cáo" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Reports"/>

                    <!-- Settings - Admin only -->
                    <Border Height="1" Background="#F3F4F6" Margin="0,10,0,10"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="HỆ THỐNG" Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" 
                               Margin="14,0,0,8"
                               Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                    <RadioButton Content="⚙️  Cài đặt" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                 Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="#F0F2F5">
            <ContentControl Content="{Binding CurrentView}" Margin="24"/>
        </Border>
    </Grid>
</Window>
