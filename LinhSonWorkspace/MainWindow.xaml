<Window x:Class="LinhSonWorkspace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LinhSonWorkspace.ViewModels"
        xmlns:views="clr-namespace:LinhSonWorkspace.Views"
        Title="Linh Son Workspace - Booking Management" 
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
            <views:WorkspaceView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerViewModel}">
            <views:CustomerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookingViewModel}">
            <views:BookingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CheckInOutViewModel}">
            <views:CheckInOutView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#16213e">
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="15,20,15,25">
                    <TextBlock Text="🏢 LINH SON" FontSize="18" FontWeight="Bold" Foreground="#00b4d8"/>
                    <TextBlock Text="WORKSPACE" FontSize="12" Foreground="#8892b0" Margin="28,0,0,0"/>
                    <Border Height="1" Background="#2d3561" Margin="0,15,0,0"/>
                </StackPanel>

                <!-- User Info at bottom -->
                <Border DockPanel.Dock="Bottom" Background="#1a1a3e" Padding="15,10" Margin="10,0,10,10" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentUserName}" Foreground="#ccd6f6" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CurrentRole}" Foreground="#64ffda" FontSize="10"/>
                        <Button Content="🚪 Đăng xuất" Command="{Binding LogoutCommand}" 
                                Style="{StaticResource SidebarButton}" Foreground="#ef4444" Margin="0,8,0,0"
                                FontSize="11" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Menu Items -->
                <StackPanel Margin="10,0">
                    <RadioButton Content="📊  Dashboard" GroupName="Menu" IsChecked="True"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
                    <RadioButton Content="🏠  Workspaces"  GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Workspaces"/>
                    <RadioButton Content="👤  Khách hàng" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Customers"/>
                    <RadioButton Content="📅  Đặt lịch" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Bookings"/>
                    <RadioButton Content="✅  Check In/Out" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="CheckInOut"/>
                    <RadioButton Content="📈  Báo cáo" GroupName="Menu"
                                 Style="{StaticResource MenuRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Reports"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="#0f0f23">
            <ContentControl Content="{Binding CurrentView}" Margin="20"/>
        </Border>
    </Grid>
</Window>
